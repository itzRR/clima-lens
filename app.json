{
  "expo": {
    "name": "ClimaLens",
    "slug": "climalens",
    "version": "1.4.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "climalens",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#090B0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.climalens.app",
      "newArchEnabled": true,
      "splash": {
        "backgroundColor": "#090B0A"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ClimaLens needs your location to show local weather and risk data.",
        "NSCameraUsageDescription": "ClimaLens needs camera access to submit community reports.",
        "NSPhotoLibraryUsageDescription": "ClimaLens needs photo access to attach images to reports."
      }
    },
    "android": {
      "newArchEnabled": true,
      "splash": {
        "backgroundColor": "#090B0A"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#090B0A"
      },
      "package": "com.climalens.app",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-font",
      "expo-location",
      "expo-image-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "50c8a397-7155-481b-bddc-2623406dc7ff"
      }
    }
  }
}
